# ========================================
# TELEGRAM BOT CONFIGURATION
# ========================================

# Token dari @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Admin User IDs (pisahkan dengan koma, tanpa spasi)
# Gunakan @userinfobot untuk mendapatkan user ID kamu
ADMIN_USER_IDS=123456789,987654321

# ========================================
# GITHUB CONFIGURATION (Opsional - default)
# ========================================
# GitHub Personal Access Token default (bisa diset per user via /settoken)
DEFAULT_GITHUB_TOKEN=

# ========================================
# AI / COPILOT CONFIGURATION
# ========================================
# Jika menggunakan OpenAI sebagai fallback AI
OPENAI_API_KEY=

# ========================================
# TERMINAL CONFIGURATION
# ========================================
# Direktori kerja default untuk terminal
TERMINAL_WORKING_DIR=/tmp/telegram-shell

# Timeout eksekusi perintah (detik)
COMMAND_TIMEOUT=30

# ========================================
# OPTIONAL: DATABASE untuk menyimpan sesi user
# ========================================
# Kosongkan untuk menggunakan penyimpanan lokal (file JSON)
DATABASE_URL=
